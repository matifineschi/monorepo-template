{
	"name": "my-turborepo",
	"private": true,
	"catalog": {
		"next": "16.2.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"typescript": "5.9.2",
		"@types/node": "^22.15.3",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"@biomejs/biome": "2.3.8",
		"turbo": "^2.9.5",
		"@turbo/gen": "^2.9.5",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"@tailwindcss/postcss": "^4.2.2"
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --parallel",
		"lint": "turbo run lint",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"gen:package": "turbo gen package",
		"knip": "knip",
		"db:up": "docker compose up -d",
		"db:down": "docker compose down",
		"db:reset": "docker compose down -v && docker compose up -d"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@turbo/gen": "catalog:",
		"@types/node": "^25.6.0",
		"knip": "^6.3.1",
		"turbo": "catalog:",
		"typescript": "^6.0.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"apps/*",
		"packages/*",
		"packages/infra/*"
	]
}
